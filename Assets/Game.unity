    - target: {fileID: 1043936208367258985, guid: b6500afb0f59a2440ad7354e9f83a607, type: 3}
      propertyPath: dialogues.Array.data[1]
      value: "\u0531\u0575\u057D\u057F\u0565\u0572 \u0577\u0561\u057F\u0565\u0580\u0576
        \u0565\u0576 \u0565\u056F\u0565\u056C \u0578\u057D\u056F\u0578\u0582 \u0570\u0565\u057F\u0587\u056B\u0581
        \u0562\u0561\u0575 \u0574\u0561\u0570\u0561\u0581\u0565\u056C \u0565\u0576
        \u056B\u0576\u0579\u057A\u0565\u057D \u057F\u0565\u057D\u0576\u0582\u0574\u0565\u057D"
      objectReference: {fileID: 0}
    - target: {fileID: 1043936208367258985, guid: b6500afb0f59a2440ad7354e9f83a607, type: 3}
      propertyPath: dialogues.Array.data[2]
      value: "\u0535\u057D \u056E\u0565\u0580\u0561\u0581\u0565\u056C \u0565\u0574
        \u0587 \u056B\u0576\u0571 \u057A\u0565\u057F\u0584 \u0567 \u0583\u0578\u056D\u0561\u0576\u0561\u056F\u0578\u0572"
