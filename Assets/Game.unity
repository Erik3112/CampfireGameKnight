    - target: {fileID: 1043936208367258985, guid: b6500afb0f59a2440ad7354e9f83a607, type: 3}
      propertyPath: dialogues.Array.data[3]
      value: "\u0535\u057D \u0584\u0578 \u0574\u0561\u057D\u056B\u0576 \u0577\u0561\u057F
        \u0565\u0574 \u056C\u057D\u0565\u056C \u0587 \u0565\u057D \u056F\u0578\u0582\u0566\u0565\u0576\u0561\u056B
        \u0578\u0580 \u0564\u0578\u0582 \u056B\u0576\u0571 \u0583\u0578\u056D\u0561\u0576\u0561\u056F\u0565\u057D"
      objectReference: {fileID: 0}
    - target: {fileID: 1043936208367258985, guid: b6500afb0f59a2440ad7354e9f83a607, type: 3}
      propertyPath: dialogues.Array.data[4]
      value: "\u0535\u054E \u0564\u0578\u0582 \u056F\u0561\u0580\u0578\u0572\u0561\u0581\u0561\u0580
